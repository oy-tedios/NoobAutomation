#!/bin/bash
# Confluence 자동화 CLI
# 사용법: cf weekly | cf release [버전]

SCRIPT_DIR="$(dirname "$(realpath "$0")")"
PYTHON_SCRIPT="$SCRIPT_DIR/confluence_automation.py"

if [[ $# -eq 0 ]]; then
    echo "사용법:"
    echo "  cf weekly                  주간업무보고 생성"
    echo "  cf release [버전]          iOS 릴리즈노트 생성"
    echo "  cf release-android [버전]  Android 릴리즈노트 생성"
    exit 0
fi

case "$1" in
    weekly)
        python3 "$PYTHON_SCRIPT" weekly
        ;;
    release)
        if [[ -n "$2" ]]; then
            python3 "$PYTHON_SCRIPT" release ios "$2"
        else
            python3 "$PYTHON_SCRIPT" release ios
        fi
        ;;
    release-android)
        if [[ -n "$2" ]]; then
            python3 "$PYTHON_SCRIPT" release android "$2"
        else
            python3 "$PYTHON_SCRIPT" release android
        fi
        ;;
    *)
        echo "❌ 알 수 없는 명령: $1"
        echo "사용법: cf weekly | cf release [버전] | cf release-android [버전]"
        exit 1
        ;;
esac
